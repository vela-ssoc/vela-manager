# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

.idea/

# 配置文件（敏感信息）
zone/conf/manager.yaml
zone/conf/manager-*.yaml

# 内部证书（敏感信息）
zone/tls/*.crt
zone/tls/*.key
zone/tls/*.pem
zone/tls/*.der
zone/tls/*.cer
zone/tls/*.pfx
zone/tls/*.p12
zone/tls/*.req
zone/tls/*.csr
zone/tls/*.jks

# 其他测试临时目录
zone/temp/
zone/log/
